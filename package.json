{
  "name": "email-sender",
  "version": "0.1.0",
  "description": "Huglo module that sends email via per-subject SMTP configuration",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sonar": "dotenv -- sonar",
    "sonar:ci": "npm run test:coverage && npm run sonar"
  },
  "dependencies": {
    "@huglo/module-sdk": "^1.1.0",
    "dotenv": "^17.4.2",
    "nodemailer": "^8.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sonar/scan": "^4.3.6",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
