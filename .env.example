# Ed25519 private key (PEM file path)
MODULE_PRIVATE_KEY_PATH=./private.pem

# Public base URL registered in Huglo (must match what you submitted in the UI)
MODULE_ENDPOINT=https://your-module.example.com

# Huglo registration challenge (issued by Huglo UI during pending registration)
MODULE_CHALLENGE=

# HTTP listen port
PORT=3200

# Config UI OAuth (required for /config login)
HUGLO_OAUTH_CLIENT_ID=
HUGLO_OAUTH_CLIENT_SECRET=
HUGLO_OAUTH_REDIRECT_URI=https://your-module.example.com/config/callback

# SonarQube (required if you want to run sonar)
# SONAR_HOST_URL=https://sonar.qxp.sk
# SONAR_TOKEN=
